{
  "name": "cleanventures-api",
  "version": "1.0.0",
  "description": "CleanVentures backend API — Node.js + TypeScript + Fastify + Supabase",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format cjs --out-dir dist --no-splitting",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@supabase/supabase-js": "^2.43.4",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "stream-chat": "^9.41.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "pino-pretty": "^11.0.0",
    "tsup": "^8.1.0",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  }
}
